<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/status_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_status_bg"
    android:padding="12dp">

    <!-- Top: profile name + battery -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/status_profile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end"
            android:text="—" />

        <TextView
            android:id="@+id/status_battery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#BBFFFFFF"
            android:textSize="12sp"
            android:layout_marginStart="6dp"
            android:text="—" />

    </LinearLayout>

    <!-- Middle: dot + sentinel state text -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="8dp">

        <ImageView
            android:id="@+id/status_dot"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:src="@drawable/widget_status_dot"
            android:layout_marginEnd="8dp"
            android:contentDescription="Sentinel state" />

        <TextView
            android:id="@+id/status_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:singleLine="true"
            android:ellipsize="end"
            android:text="—" />

    </LinearLayout>

    <!-- Bottom: active modes -->
    <TextView
        android:id="@+id/status_modes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="#99FFFFFF"
        android:textSize="11sp"
        android:singleLine="true"
        android:ellipsize="end"
        android:text="" />

</LinearLayout>
